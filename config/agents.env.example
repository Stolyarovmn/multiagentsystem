# Optional overrides for multiagentsystem

# Session names
EXECUTOR_SESSION=executor-main
AUDITOR_SESSION=auditor-main
WATCHDOG_SCREEN=mas-watchdog

# Launch commands.
# If left empty, start.sh will try auto-detection:
# executor -> codex / claude / gemini
# auditor  -> gemini / codex / claude
# If no suitable CLI is found, a shell session is left open for manual launch.
EXECUTOR_LAUNCH_CMD=
AUDITOR_LAUNCH_CMD=

# Runtime knobs
WATCHDOG_POLL_INTERVAL=2
COORDINATOR_INTERVAL_MIN=3
ENABLE_CRON_SETUP=1
ENVELOPE_MAX_BYTES=4096
STALL_WINDOW_MIN=12
STARTUP_SEND_ROLE=1

# Optional default target pack.
# Example: DEFAULT_TARGET_PACK=targets/example.local.md
# Leave empty to keep the system generic until set-target.sh is used.
DEFAULT_TARGET_PACK=
