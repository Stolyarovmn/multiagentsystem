# Optional local overrides for multiagentsystem

EXECUTOR_SESSION=executor-main
AUDITOR_SESSION=auditor-main
WATCHDOG_SCREEN=multiagentsystem-watchdog

# Leave blank to auto-detect codex/claude/gemini, or open a shell if none is found.
EXECUTOR_LAUNCH_CMD=
AUDITOR_LAUNCH_CMD=

WATCHDOG_POLL_INTERVAL=2
COORDINATOR_INTERVAL_MIN=3
ENABLE_CRON_SETUP=0
ENVELOPE_MAX_BYTES=4096
STARTUP_SEND_ROLE=1
DEFAULT_TARGET_PACK=
